{
    "manifest_version": 3,
    "name": "Google Slide Reception System",
    "version": "1.0.1",
    "description": "GoogleSlideの横に受付通知を表示します",
    "permissions": ["scripting", "storage"],
    "options_page": "options.html",
    "content_scripts": [
      {
        "js": ["content.js", "socket.io.min.js"],
        "matches": ["https://docs.google.com/presentation/*"]
      },
      {
        "css": ["content.css"],
        "matches": ["https://docs.google.com/presentation/*"]
      }
    ]
}
